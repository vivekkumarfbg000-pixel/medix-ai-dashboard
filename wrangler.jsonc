{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "medix-ai-dashboard",
  "main": "src/worker.ts",
  "compatibility_date": "2024-04-01",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
